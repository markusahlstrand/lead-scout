{
  "name": "lead-scout",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.3",
  "scripts": {
    "dev": "wrangler pages dev",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "wrangler pages deploy dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply lead-scout-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply lead-scout-db --remote",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "hono": "^4.12.0",
    "drizzle-orm": "^0.45.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.0",
    "@tanstack/react-query": "^5.75.0",
    "lucide-react": "^0.500.0",
    "recharts": "^2.15.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0",
    "class-variance-authority": "^0.7.0",
    "date-fns": "^4.1.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^4.4.0",
    "wrangler": "^4.0.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "bash -c 'pnpm typecheck'"
  }
}
